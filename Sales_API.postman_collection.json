{
  "info": {
    "_postman_id": "ambev-sales-api-collection",
    "name": "Sales API — Mouts Backend Challenge",
    "description": "Full coverage collection for the Sales API. Run 'Create Sale (saves IDs)' first — it populates {{sale_id}} and {{product_id}} used by all other requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://localhost:8081", "type": "string" },
    { "key": "sale_id",   "value": "", "type": "string" },
    { "key": "product_id","value": "", "type": "string" },
    { "key": "sale_number","value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Create Sale",
      "item": [
        {
          "name": "✅ Valid — 1 item, no discount",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('sale_number', 'SALE-' + Date.now());",
                  "pm.collectionVariables.set('product_id', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Success true', () => pm.expect(body.success).to.be.true);",
                  "pm.test('Has sale ID', () => pm.expect(body.data.id).to.be.a('string'));",
                  "pm.test('Discount is 0', () => pm.expect(body.data.items[0].discount).to.eql(0));",
                  "pm.collectionVariables.set('sale_id', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/sales",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleNumber\": \"{{sale_number}}\",\n  \"saleDate\": \"2025-06-25T10:00:00Z\",\n  \"customerId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"customerName\": \"Ambev Distribuidora\",\n  \"branchId\": \"4fa85f64-5717-4562-b3fc-2c963f66afa7\",\n  \"branchName\": \"São Paulo\",\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"productName\": \"Brahma 600ml\",\n      \"unitPrice\": 5.50,\n      \"quantity\": 3\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "✅ Valid — 4 items, 10% discount",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('sale_number', 'SALE4-' + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Discount is 10%', () => pm.expect(body.data.items[0].discount).to.eql(0.1));",
                  "pm.test('TotalAmount = 4 * 5.50 * 0.90 = 19.80', () => pm.expect(body.data.items[0].totalAmount).to.eql(19.8));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/sales",
